# =============================================================================
# AI Resume Screening System — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value marked <CHANGE_ME>
#   3. NEVER commit your .env file to version control (it is in .gitignore)
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config for development):
DATABASE_URL=sqlite:///./app.db

# PostgreSQL (swap for production — just change this one line):
# DATABASE_URL=postgresql://user:password@localhost:5432/resume_screening_db

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<CHANGE_ME_generate_a_strong_random_secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
# The URL of your Next.js frontend (no trailing slash)
FRONTEND_ORIGIN=http://localhost:3000

# ─── File Upload Limits ───────────────────────────────────────────────────────
# Maximum resume file size in bytes (default: 5MB = 5242880)
MAX_FILE_SIZE_BYTES=5242880

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ─── Email Verification (Simulated in Dev) ───────────────────────────────────
# Base URL used to construct verification links printed to the terminal
VERIFY_BASE_URL=http://localhost:8000

# ─── Production SMTP (Uncomment & fill when moving to production) ─────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=<CHANGE_ME_sendgrid_api_key>
# EMAILS_FROM_ADDRESS=noreply@yourapp.com
